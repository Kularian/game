    xpos naoyax-30 ypos naoyay-70 alpha 0.1
    linear 0.7 ypos naoyay-120 alpha 0.6
    linear 0.3 xpos naoyax-50 alpha 0.0
transform personasummonnaoya2:
    xpos naoyax-50 ypos naoyay-120 alpha 0.2
    linear 0.3 xpos naoyax-70 alpha 0.6
    linear 0.7 xpos naoyax-120 ypos naoyay-70
    linear 0.3 ypos naoyay-110
    linear 0.3 xpos naoyax-100 alpha 0.0
transform personasummonnaoya3:
    xpos naoyax-90 ypos naoyay-110 alpha 0.6
    linear 0.4 xpos naoyax-60 alpha 0.0
transform personasummonnaoya4:
    xpos naoyax-60 ypos naoyay-110 alpha 0.6
    linear 0.1 xpos naoyax-10
transform personasummonnaoyatalk:
    xpos naoyax ypos naoyay-110 alpha 0.6
    linear 2.0 ypos naoyay-160
    linear 2.0 ypos naoyay-110
    repeat

